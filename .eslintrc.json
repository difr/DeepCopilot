{
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "commonjs"
  },
  "globals": {
    "acquireVsCodeApi": "readonly"
  },
  "rules": {
    "no-eval": "error",
    "no-implied-eval": "error",
    "no-new-func": "error",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "warn",
    "eqeqeq": ["error", "always", {"null": "ignore"}],
    "indent": ["warn", 2],
    "quotes": ["warn", "single"],
    "semi": ["warn", "always"],
    "no-var": "error",
    "prefer-const": "warn"
  },
  "ignorePatterns": [
    "out/",
    "node_modules/",
    "release/",
    "media/katex.min.js",
    "media/purify.min.js"
  ]
}
