{
  "$schema": "./_schema.json",
  "id": "anthropic",
  "displayName": "Anthropic",
  "baseUrl": "https://api.anthropic.com",
  "apiKeyUrl": "https://console.anthropic.com/settings/keys",
  "protocol": "anthropic",
  "defaultModel": "claude-opus-4-7",
  "subAgentModel": "claude-sonnet-4-6",
