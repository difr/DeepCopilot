      "contextWindow": 200000,
      "maxOutputTokens": 32000,
      "capabilities": { "tools": true, "reasoning": true, "vision": true }
    },
    {
      "id": "claude-opus-4-6",
      "displayName": "Claude Opus 4.6",
      "contextWindow": 200000,
      "maxOutputTokens": 32000,
      "capabilities": { "tools": true, "reasoning": true, "vision": true }
    },
    {
      "id": "claude-sonnet-4-6",
      "displayName": "Claude Sonnet 4.6",
      "contextWindow": 200000,
      "maxOutputTokens": 64000,
      "capabilities": { "tools": true, "reasoning": true, "vision": true }
    }
  ]
